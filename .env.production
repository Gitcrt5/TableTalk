# Production Environment Configuration
NODE_ENV=production
USE_REPLIT_AUTH=false
VITE_USE_REPLIT_AUTH=false

# Database Configuration
# DATABASE_URL will be automatically set by Replit deployment
# No DEV_DATABASE_URL needed in production

# Admin Configuration
ADMIN_EMAIL=admin@tabletalk.cards
# ADMIN_PASSWORD should be set in Replit secrets

# Email Service (set in Replit secrets)
# SENDGRID_API_KEY should be set in Replit secrets

# Application Settings
BASE_URL=https://tabletalk.replit.app